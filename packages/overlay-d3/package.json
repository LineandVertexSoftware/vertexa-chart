{
  "name": "@lineandvertexsoftware/overlay-d3",
  "version": "0.1.9",
  "description": "D3.js overlay for interactive axes, zoom, and legends",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "pnpm build && c8 node --experimental-test-module-mocks --test test/*.test.mjs",
    "coverage": "c8 report --reporter=html",
    "clean": "rm -rf dist tsconfig.tsbuildinfo coverage",
    "prepublishOnly": "pnpm build",
    "typecheck": "tsc --noEmit"
  },
  "c8": {
    "all": true,
    "src": "src",
    "include": [
      "src/**/*.ts"
    ],
    "reporter": [
      "text",
      "html",
      "lcov"
    ]
  },
  "dependencies": {
    "d3": "^7.9.0"
  },
  "devDependencies": {
    "@types/d3": "^7.4.3",
    "jsdom": "^28.1.0",
    "typescript": "^5.6.3"
  },
  "sideEffects": false,
  "keywords": [
    "d3",
    "overlay",
    "zoom",
    "axes",
    "legend",
    "interaction"
  ],
  "author": "Vertexa contributors",
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/LineandVertexSoftware/vertexa-chart.git",
    "directory": "packages/overlay-d3"
  },
  "homepage": "https://github.com/LineandVertexSoftware/vertexa-chart#readme",
  "bugs": {
    "url": "https://github.com/LineandVertexSoftware/vertexa-chart/issues"
  },
  "publishConfig": {
    "access": "public"
  }
}
