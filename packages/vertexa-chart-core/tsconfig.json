{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "paths": {
      "@vertexa-chart/overlay-d3": ["./packages/overlay-d3/dist/index.d.ts"],
      "@vertexa-chart/renderer-webgpu": ["./packages/renderer-webgpu/dist/index.d.ts"]
    },
    "outDir": "./dist",
    "rootDir": "./src",
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "composite": true,
    "noEmit": false,
    "tsBuildInfoFile": "./tsconfig.tsbuildinfo"
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist", "test"]
}
