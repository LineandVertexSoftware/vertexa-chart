{
  "name": "@lineandvertexsoftware/renderer-webgpu",
  "version": "0.1.11",
  "description": "WebGPU rendering engine for high-performance visualization",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc && node scripts/copy-shaders.js",
    "dev": "tsc --watch",
    "test": "pnpm build && c8 node --experimental-test-module-mocks --loader ./test/wgsl-loader.mjs --test test/*.test.mjs",
    "coverage": "c8 report --reporter=html",
    "clean": "rm -rf dist tsconfig.tsbuildinfo coverage",
    "prepublishOnly": "pnpm build",
    "typecheck": "tsc --noEmit"
  },
  "c8": {
    "all": true,
    "src": "src",
    "include": ["src/**/*.ts"],
    "reporter": ["text", "html", "lcov"]
  },
  "devDependencies": {
    "@webgpu/types": "^0.1.68",
    "typescript": "^5.6.3"
  },
  "sideEffects": false,
  "keywords": [
    "webgpu",
    "gpu",
    "rendering",
    "graphics",
    "shaders"
  ],
  "author": "Vertexa contributors",
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/LineandVertexSoftware/vertexa-chart.git",
    "directory": "packages/renderer-webgpu"
  },
  "homepage": "https://github.com/LineandVertexSoftware/vertexa-chart#readme",
  "bugs": {
    "url": "https://github.com/LineandVertexSoftware/vertexa-chart/issues"
  },
  "publishConfig": {
    "access": "public"
  }
}
